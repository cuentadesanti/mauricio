# .env.example

# auth
BACKEND_API_KEY=your_backend_api_key_here

# langfuse cloud
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# db
DATABASE_URL=postgresql+asyncpg://ai:ai@postgres:5432/personalai

# providers
ANTHROPIC_API_KEY=sk-ant-xxxxx
TAVILY_API_KEY=tvly-xxxxx
OPENAI_API_KEY=sk-xxxxx

# smart home
KASA_USERNAME=your@email.com
KASA_PASSWORD=your_kasa_password
LAMP_HOST=192.168.1.x

# routing
DEFAULT_USER_HANDLE=me
DEFAULT_MODEL=anthropic/claude-haiku-4-5
STRONG_MODEL=anthropic/claude-opus-4-7

# Phase 4 — WhatsApp (Evolution API)
# EVOLUTION_API_URL=http://evolution:8080
# EVOLUTION_API_KEY=your_evolution_key
# EVOLUTION_INSTANCE=mauricio
# EVOLUTION_WEBHOOK_TOKEN=your_webhook_token

# Phase 5 — Self-improvement loop
# REPO_ROOT=/app                          # absolute path to repo root inside the container
# GITHUB_REPO=cuentadesanti/mauricio      # used for gh pr create
