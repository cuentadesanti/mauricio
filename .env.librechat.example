# .env.librechat.example

HOST=0.0.0.0
PORT=3080
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=dev-master-key-change-me

# obligatorios — generales para LibreChat
CREDS_KEY=your_creds_key_here
CREDS_IV=your_creds_iv_here
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# permitir registro libre solo localmente; cambia en prod
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true

# punto al backend custom
BACKEND_API_KEY=your_backend_api_key_here

# desactiva endpoints que no usas
ENDPOINTS=custom
